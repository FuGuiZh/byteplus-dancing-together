# BytePlus 区域，用于 ModelArk 和素材库 OpenAPI。
BYTEPLUS_REGION=ap-southeast-1

# IAM AK/SK 只允许后端使用，用于调用 BytePlus OpenAPI：
# CreateVisualValidateSession、GetVisualValidateResult、CreateAssetGroup、
# CreateAsset、GetAsset、ListAssets 以及相关素材管理接口。
BYTEPLUS_IAM_ACCESS_KEY_ID=
BYTEPLUS_IAM_SECRET_ACCESS_KEY=

# ModelArk API Key 只允许后端使用，用于调用推理接口：
# POST /api/v3/contents/generations/tasks
# GET  /api/v3/contents/generations/tasks/{id}
BYTEPLUS_MODELARK_API_KEY=

# ProjectName 必须在真人认证、素材上传、素材查询和推理 endpoint 项目之间保持一致。
BYTEPLUS_PROJECT_NAME=default

# Seedance endpoint ID 会作为视频生成请求里的 "model" 字段传给 BytePlus。
BYTEPLUS_SEEDANCE_2_ENDPOINT_ID=ep-20260xxxxxxxxx-xxxxx
BYTEPLUS_SEEDANCE_2_FAST_ENDPOINT_ID=ep-20260xxxxxxxx-xxxxx

# Demo 应用或后端的公网地址，用于接收 BytePlus 回调。
APP_PUBLIC_URL=http://localhost:3000
BYTEPLUS_REAL_PERSON_CALLBACK_URL=http://localhost:3000/api/byteplus/real-person-callback
BYTEPLUS_VIDEO_TASK_CALLBACK_URL=http://localhost:3000/api/byteplus/video-task-callback

# Demo 默认生成参数。
DEFAULT_VIDEO_RATIO=9:16
DEFAULT_VIDEO_DURATION=8
DEFAULT_VIDEO_RESOLUTION=720p
DEFAULT_GENERATE_AUDIO=true
DEFAULT_USE_FAST_ENDPOINT=false

# 轮询设置，用作回调失败或延迟时的兜底。
ASSET_POLL_INTERVAL_MS=5000
VIDEO_TASK_POLL_INTERVAL_MS=15000

# 本地开发开关。
MOCK_BYTEPLUS=false
LOG_BYTEPLUS_PAYLOADS=false
